# Mode de déploiement : "development" (tolère les valeurs par défaut, alerte)
# ou "production" (garde-fous stricts : refuse de démarrer si JWT_SECRET est faible).
ENVIRONMENT=development

BACKEND_PORT=8000
FRONTEND_PORT=4200
STOCKFISH_PATH=/usr/games/stockfish
CHESSDB_BASE=https://www.chessdb.cn
LICHESS_EXPLORER_BASE=https://explorer.lichess.ovh
HTTP_TIMEOUT_SECONDS=10
LOG_LEVEL=INFO

# Milvus (vector DB pour le RAG)
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=wikichess_chunks

# OpenAI (embeddings + LLM agent)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_KEY
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIM=3072
# Modèle LLM utilisé par l'agent. 
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_CHAT_TEMPERATURE=0.3

# YouTube Data API v3
# Génère une clé : https://console.cloud.google.com → activer YouTube Data API v3 → API key
# Tier gratuit : 10 000 units/jour, 1 search = 100 units → max ~100 calls/jour
YOUTUBE_API_KEY=REPLACE_WITH_YOUR_KEY
YOUTUBE_API_BASE=https://www.googleapis.com/youtube/v3

# MongoDB (checkpoints LangGraph + futurs caches)
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_DB=chess_agent

# Auth (JWT email/password) + quota par compte
# JWT_SECRET : générer avec `openssl rand -hex 32` (>= 32 caractères).
# En ENVIRONMENT=production, garder la valeur par défaut ci-dessous fait
# ÉCHOUER le démarrage (fail-closed) — c'est volontaire.
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
# Durée de validité d'un token (en minutes). 10080 = 7 jours.
JWT_EXPIRE_MINUTES=10080
# Nombre de messages /chat autorisés à vie par compte. Reset manuel via Mongo.
MESSAGE_QUOTA_PER_USER=50
# Rate-limit sur /auth/signup (par IP). Syntaxe slowapi : <count>/<period>.
SIGNUP_RATE_LIMIT=5/hour
